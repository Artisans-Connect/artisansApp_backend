# Application Environment (development, production, test)
NODE_ENV=development

# Port to run the Express server
PORT=3000

# Supabase Credentials (from Supabase Dashboard API Settings)
# Note: Express backend runs with service_role key to bypass RLS for administrative actions.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Firebase Service Account Credentials (for FCM Push Notifications)
# Path to the JSON service account file relative to the root directory
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/firebase-service-account.json
